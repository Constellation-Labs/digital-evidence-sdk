{
  "name": "@constellation-network/digital-evidence-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the Digital Evidence Depository (DED) on Constellation Network",
  "main": "dist/cjs/core/index.js",
  "module": "dist/esm/core/index.js",
  "types": "dist/types/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/core/index.js",
      "require": "./dist/cjs/core/index.js",
      "types": "./dist/types/core/index.d.ts"
    },
    "./network": {
      "import": "./dist/esm/network/index.js",
      "require": "./dist/cjs/network/index.js",
      "types": "./dist/types/network/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "rollup -c",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "constellation",
    "ded",
    "digital-evidence",
    "fingerprint",
    "notarization",
    "metagraph",
    "secp256k1",
    "rfc8785",
    "cryptographic-proof"
  ],
  "author": "Constellation Network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constellation-Labs/digital-evidence-sdk.git",
    "directory": "packages/typescript"
  },
  "dependencies": {
    "@constellation-network/metagraph-sdk": "^0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.59.0",
    "ts-jest": "^29.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
